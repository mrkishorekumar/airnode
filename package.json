    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint ./app --cache",
    "format": "prettier --write \"app/**/*.{js,jsx,ts,tsx,json,md}\"",
    "check": "prettier --write \"app/**/*.{js,jsx,ts,tsx,json,md}\" && eslint ./app --cache "
  },
